{% extends 'public.html.twig' %}

{% block title %}Message envoyé - Vite & Gourmand{% endblock %}

{% block body %}
<main class="flex-grow flex items-center justify-center py-20 px-6 md:px-12 bg-background-light">
    <div class="max-w-lg w-full mx-auto">
        <div class="bg-white rounded-2xl shadow-soft p-8 md:p-12 border border-gray-100 text-center">
            <div class="mb-6 flex justify-center">
                <div class="w-20 h-20 rounded-full bg-gold/10 flex items-center justify-center">
                    <span class="material-icons-outlined text-gold text-5xl">check_circle</span>
                </div>
            </div>
            <h1 class="font-display font-bold text-3xl md:text-4xl text-text-main-light mb-4">Message envoyé avec succès !</h1>
            <p class="text-lg text-gray-600 font-body mb-8">
                Merci de nous avoir contactés. Notre équipe gourmande vous répondra par email dans les plus brefs délais.
            </p>
            <div class="pt-2 text-center">
                <a class="inline-block w-full md:w-auto min-w-[200px] bg-primary hover:bg-red-900 text-white font-bold py-4 px-8 rounded-pill shadow-lg hover:shadow-xl transition-all transform hover:-translate-y-1 text-base tracking-wide uppercase" href="{{ path('app_home') }}">
                    Retour à l'accueil
                </a>
            </div>
        </div>
    </div>
</main>
{% endblock %}
