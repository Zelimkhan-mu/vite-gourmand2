{% extends 'public.html.twig' %}

{% block title %}{{ menu.titre }} - Vite & Gourmand{% endblock %}

{% block body %}
    <main class="flex-grow pt-8 pb-20">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-16">
                
                <div class="lg:col-span-7 pt-4">
                    
                    <div class="flex gap-4 mb-8">
                        <span class="inline-block bg-red-100 text-text-main-light text-[10px] font-bold px-4 py-2 uppercase tracking-widest">{{ menu.theme.nom }}</span>
                        {% if menu.regime.nom != 'Classique' %}
                            <span class="inline-block bg-red-100 text-text-main-light text-[10px] font-bold px-4 py-2 uppercase tracking-widest">{{ menu.regime.nom }}</span>
                        {% endif %}
                    </div>

                    <h1>
                        {{ menu.titre }}
                    </h1>

                    <div class="mb-4 w-full">
                        {% import 'partials/_macros.html.twig' as macros %}
                        {% set couverturePath = macros.get_menu_cover_path(menu)|trim %}

                        {% if couverturePath %}
                            <img src="{{ asset('images/' ~ couverturePath) }}" alt="{{ menu.titre }}" class="w-full h-auto object-cover">
                        {% else %}
                            <div class="w-full h-96 bg-gray-200 flex items-center justify-center text-gray-400">Pas d'image</div>
                        {% endif %}
                    </div>
                    
                    <div class="grid grid-cols-4 gap-4 mb-16">
                        {% for plat in menu.plats %}
                            {% for image in plat.images %}
                                <div class="aspect-square bg-gray-100 flex items-center justify-center overflow-hidden relative group">
                                    <img src="{{ asset('images/' ~ image.imagePath) }}" class="w-full h-full object-cover transition duration-300 group-hover:scale-110" alt="Détail du menu">
                                </div>
                            {% endfor %}
                        {% endfor %}
                    </div>

                    <div class="mb-20">
                        <h2>Présentation du menu</h2>
                        <p class="text-gray-600 font-light leading-relaxed text-base text-justify">
                            {{ menu.description }}
                        </p>
                    </div>

                    <div class="mb-20">
                        <h2>La Carte</h2>

                        {% set entrees = menu.plats|filter(p => p.type == 'entree') %}
                        {% if entrees|length > 0 %}
                        <div class="mb-10">
                            <h3>Entrée</h3>
                            {% for plat in entrees %}
                            <div class="bg-white p-8 shadow-card flex justify-between items-start group hover:shadow-lg transition duration-300 mb-4">
                                <div class="pr-8">
                                    <h4 class="font-display text-2xl text-text-main-light mb-2">{{ plat.nom }}</h4>
                                    <p class="text-sm text-gray-400 font-normal">{{ plat.description }}</p>
                                </div>
                                {% if plat.allergenes|length > 0 %}
                                <div class="whitespace-nowrap pt-1 relative group/tooltip">
                                    <span class="text-[9px] text-primary uppercase tracking-widest border-b border-transparent hover:border-primary transition cursor-help flex items-center gap-1">
                                        Allergènes <span class="material-icons-outlined text-[10px]">info</span>
                                    </span>
                                    <div class="absolute right-0 bottom-full mb-2 hidden group-hover/tooltip:block bg-gray-800 text-white text-[10px] p-2 rounded w-48 z-10 shadow-lg">
                                        {% for allergene in plat.allergenes %}
                                            {{ allergene.nom }}{% if not loop.last %}, {% endif %}
                                        {% endfor %}
                                    </div>
                                </div>
                                {% endif %}
                            </div>
                            {% endfor %}
                        </div>
                        {% endif %}

                        {% set plats = menu.plats|filter(p => p.type == 'plat') %}
                        {% if plats|length > 0 %}
                        <div class="mb-10">
                            <h3>Plat Principal</h3>
                            {% for plat in plats %}
                            <div class="bg-white p-8 shadow-card flex justify-between items-start group hover:shadow-lg transition duration-300 mb-4">
                                <div class="pr-8">
                                    <h4 class="font-display text-2xl text-text-main-light mb-2">{{ plat.nom }}</h4>
                                    <p class="text-sm text-gray-400 font-normal">{{ plat.description }}</p>
                                </div>
                                {% if plat.allergenes|length > 0 %}
                                <div class="whitespace-nowrap pt-1 relative group/tooltip">
                                    <span class="text-[9px] text-primary uppercase tracking-widest border-b border-transparent hover:border-primary transition cursor-help flex items-center gap-1">
                                        Allergènes <span class="material-icons-outlined text-[10px]">info</span>
                                    </span>
                                    <div class="absolute right-0 bottom-full mb-2 hidden group-hover/tooltip:block bg-gray-800 text-white text-[10px] p-2 rounded w-48 z-10 shadow-lg">
                                        {% for allergene in plat.allergenes %}
                                            {{ allergene.nom }}{% if not loop.last %}, {% endif %}
                                        {% endfor %}
                                    </div>
                                </div>
                                {% endif %}
                            </div>
                            {% endfor %}
                        </div>
                        {% endif %}

                        {% set desserts = menu.plats|filter(p => p.type == 'dessert') %}
                        {% if desserts|length > 0 %}
                        <div class="mb-10">
                            <h3>Dessert</h3>
                            {% for plat in desserts %}
                            <div class="bg-white p-8 shadow-card flex justify-between items-start group hover:shadow-lg transition duration-300 mb-4">
                                <div class="pr-8">
                                    <h4 class="font-display text-2xl text-text-main-light mb-2">{{ plat.nom }}</h4>
                                    <p class="text-sm text-gray-400 font-normal">{{ plat.description }}</p>
                                </div>
                                {% if plat.allergenes|length > 0 %}
                                <div class="whitespace-nowrap pt-1 relative group/tooltip">
                                    <span class="text-[9px] text-primary uppercase tracking-widest border-b border-transparent hover:border-primary transition cursor-help flex items-center gap-1">
                                        Allergènes <span class="material-icons-outlined text-[10px]">info</span>
                                    </span>
                                    <div class="absolute right-0 bottom-full mb-2 hidden group-hover/tooltip:block bg-gray-800 text-white text-[10px] p-2 rounded w-48 z-10 shadow-lg">
                                        {% for allergene in plat.allergenes %}
                                            {{ allergene.nom }}{% if not loop.last %}, {% endif %}
                                        {% endfor %}
                                    </div>
                                </div>
                                {% endif %}
                            </div>
                            {% endfor %}
                        </div>
                        {% endif %}
                    </div>

                    {% if menu.conditions|length > 0 %}
                    <div class="pt-8">
                        <h2>Conditions de prestation</h2>
                        
                        {% for condition in menu.conditions %}
                        <div class="mb-8">
                            <h3>{{ condition.titre }}</h3>
                            <p>
                                {{ condition.contenu }}
                            </p>
                        </div>
                        {% endfor %}
                    </div>
                    {% endif %}

                </div>

                <div class="lg:col-start-9 lg:col-span-4 relative">
                    <div class="sticky top-28">
                        <div class="bg-white p-10 shadow-soft">
                            
                            <div class="mb-2">
                                <span class="text-[10px] font-bold text-gold uppercase tracking-[0.2em]">À partir de</span>
                            </div>
                            <div class="flex items-baseline gap-3 mb-6">
                                <span class="font-display text-5xl md:text-6xl text-primary font-normal leading-none">{{ menu.basePrice }}€</span>
                                <span class="text-sm text-gray-400 italic font-display font-light">/ convive</span>
                            </div>

                            <div class="flex items-center gap-3 mb-10">
                                <div class="flex text-gold text-xs gap-0.5">
                                    <span class="material-icons-outlined text-sm">person</span>
                                    <span class="material-icons-outlined text-sm">person</span>
                                    <span class="material-icons-outlined text-sm">person</span>
                                </div>
                                <span class="font-display italic text-lg text-text-main-light">Minimum {{ menu.minPersons }} personnes</span>
                            </div>

                            <div class="space-y-6">
                                
                                <div class="border border-gray-200 py-3 px-5 flex justify-between items-center bg-white">
                                    <div class="flex items-center gap-2">
                                        <span class="font-display text-text-main-light font-bold text-lg">{{ menu.stock }}</span>
                                        <span class="text-xs font-display text-text-main-light">menus</span>
                                    </div>
                                    
                                    <span class="text-[10px] text-gray-300 uppercase tracking-widest font-semibold">DISPONIBLE</span>
                                </div>

                                {% if menu.stock > 0 %}
                                    <a href="{{ path('app_order', {'menu': menu.id}) }}" class="btn-primary block w-full">
                                        Commander
                                    </a>
                                {% else %}
                                    <button disabled class="btn-primary w-full opacity-50 cursor-not-allowed">
                                        Indisponible
                                    </button>
                                {% endif %}
                                
                            </div>

                        </div>
                    </div>
                </div>

            </div>
        </div>
    </main>
{% endblock %}