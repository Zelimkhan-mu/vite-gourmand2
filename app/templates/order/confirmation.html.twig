{% extends 'base.html.twig' %}

{% block title %}Vite & Gourmand - Confirmation{% endblock %}

{% block header %}
<nav class="bg-white shadow-sm py-4 px-6 md:px-12">
    <div class="max-w-7xl mx-auto flex items-center justify-between">
        <a class="flex items-center gap-3" href="{{ path('app_home') }}">
            <img src="{{ asset('images/logo.svg') }}" alt="Vite & Gourmand" class="h-10 w-auto">
            <span class="font-display font-bold text-xl tracking-wide uppercase">Vite &amp; Gourmand</span>
        </a>
    </div>
</nav>
{% endblock %}

{% block body %}
<main class="flex-grow flex items-center justify-center py-12 px-4">
    <div class="max-w-2xl w-full bg-white rounded-2xl shadow-soft p-8 md:p-12 text-center border border-gray-50">
        <div class="mb-8 flex justify-center">
            <div class="w-20 h-20 rounded-full border-4 border-gold/20 flex items-center justify-center bg-white">
                <span class="material-icons-outlined text-gold text-5xl font-bold">check</span>
            </div>
        </div>

        <h1>Merci pour votre commande !</h1>
        <p class="font-semibold mb-6">Numéro de commande : <span class="text-primary">#VG-{{ commande.id }}</span></p>
        <p class="max-w-lg mx-auto mb-10">
            Votre commande a bien été reçue et est en cours de préparation. <br class="hidden sm:block"/>
            Un email de confirmation vient de vous être envoyé.
        </p>

        <div class="bg-[#F9F9F9] rounded-xl p-6 md:p-8 text-left mb-10 border border-gray-100">
            <h2 class="text-xl mb-6 pb-2 border-b border-gray-200">Récapitulatif de la commande</h2>
            <div class="space-y-4">
                <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center gap-1">
                    <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-0">Date & Heure</p>
                    <p class="font-semibold mb-0">{{ commande.dateLivraison|date('d/m/Y') }} à {{ commande.heureLivraison|date('H:i') }}</p>
                </div>
                <div class="flex flex-col sm:flex-row sm:justify-between sm:items-start gap-1">
                    <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-0">Adresse</p>
                    <p class="font-semibold sm:text-right mb-0">
                        {{ commande.adresseLivraison }}, {{ commande.codePostalLivraison }} {{ commande.villeLivraison }}
                    </p>
                </div>
                <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center gap-1">
                    <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-0">Menu</p>
                    <p class="font-semibold mb-0">{{ commande.menu.titre }} ({{ commande.numPersons }} personnes)</p>
                </div>
            </div>
            <div class="mt-8 pt-6 border-t border-gray-200 flex justify-between items-center">
                <span class="font-display font-bold text-lg">Montant total</span>
                <span class="font-display font-bold text-2xl text-primary">{{ commande.prixTotal|number_format(2, ',', ' ') }} €</span>
            </div>
        </div>

        <a class="btn-primary px-10" href="{{ path('app_home') }}">
            Retour à l'accueil
        </a>
    </div>
</main>
{% endblock %}