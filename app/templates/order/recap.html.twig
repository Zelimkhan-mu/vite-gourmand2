{% extends 'base.html.twig' %}

{% block title %}Vite & Gourmand - Récapitulatif{% endblock %}

{% block header %}
<nav class="bg-white shadow-sm py-4 px-6 md:px-12">
    <div class="max-w-7xl mx-auto flex items-center justify-between">
        <a class="flex items-center gap-3" href="{{ path('app_home') }}">
            <img src="{{ asset('images/logo.svg') }}" alt="Vite & Gourmand" class="h-10 w-auto">
            <span class="font-display font-bold text-xl tracking-wide uppercase">Vite &amp; Gourmand</span>
        </a>
    </div>
</nav>
{% endblock %}

{% block body %}
<main class="flex-grow py-12 px-4 flex items-center justify-center">
    <div class="max-w-4xl w-full">
        <div class="text-center mb-12">
            <h1>Récapitulatif commande</h1>
            <p class="max-w-md mx-auto">Veuillez vérifier les détails de votre prestation avant de procéder à la commande.</p>
        </div>

        <div class="bg-white rounded-2xl shadow-soft overflow-hidden">
            <div class="p-8 md:p-10 border-b border-gray-100">
                <h2 class="flex items-center gap-3">
                    <span class="w-1.5 h-6 bg-gold rounded-full"></span>
                    Vos informations
                </h2>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-y-8 gap-x-12">
                    <div>
                        <p class="text-[10px] uppercase tracking-widest text-gray-400 font-bold mb-2">Identité & Contact</p>
                        <p class="text-lg font-semibold text-primary mb-0">{{ order.firstname }} {{ order.lastname }}</p>
                        <p class="mt-1 mb-0">{{ order.phone }}</p>
                    </div>
                    <div>
                        <p class="text-[10px] uppercase tracking-widest text-gray-400 font-bold mb-2">Lieu de livraison</p>
                        <p class="text-lg font-semibold text-primary leading-tight mb-0">
                            {{ order.address }}<br/>
                            {{ order.zipcode }} {{ order.city }}
                        </p>
                    </div>
                    <div class="md:col-span-2 flex flex-wrap gap-x-12 gap-y-4 pt-4 border-t border-gray-50">
                        <div>
                            <p class="text-[10px] uppercase tracking-widest text-gray-400 font-bold mb-1">Date demandée</p>
                            <p class="font-semibold mb-0">{{ order.delivery_date|date('d/m/Y') }}</p>
                        </div>
                        <div>
                            <p class="text-[10px] uppercase tracking-widest text-gray-400 font-bold mb-1">Heure de livraison</p>
                            <p class="font-semibold mb-0">{{ order.delivery_time }}</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="p-8 md:p-10 border-b border-gray-100">
                <h2 class="flex items-center gap-3">
                    <span class="w-1.5 h-6 bg-gold rounded-full"></span>
                    Votre sélection
                </h2>
                <div class="flex flex-col sm:flex-row items-center gap-6 bg-gray-50/50 p-4 rounded-xl border border-gray-100">
                    <div class="w-32 h-24 bg-gray-200 rounded-lg overflow-hidden flex-shrink-0 shadow-sm">
                        {% if menu.couverture %}
                             <img alt="{{ menu.couverture.altText|default(menu.titre) }}" class="w-full h-full object-cover" 
                                 src="{{ asset('images/' ~ menu.couverture.imagePath) }}"/>
                        {% else %}
                             <div class="w-full h-full bg-gray-200 flex items-center justify-center text-gray-400 text-xs">Pas d'image</div>
                        {% endif %}
                    </div>
                    <div class="text-center sm:text-left">
                        <h3 class="mb-1">{{ menu.titre }}</h3>
                        <p class="text-sm mt-1 mb-0">
                            Nombre de personnes : <span class="font-semibold text-text-main-light">{{ order.people_count }}</span>
                        </p>
                    </div>
                </div>
            </div>

            <div class="p-8 md:p-10 bg-gray-50/30">
                <h2 class="flex items-center gap-3">
                    <span class="w-1.5 h-6 bg-gold rounded-full"></span>
                    Détail du paiement
                </h2>
                <div class="bg-[#F9F9F9] border border-gray-100 rounded-xl p-6 mb-8">
                    <div class="space-y-4">
                        <div class="flex justify-between items-center text-sm">
                            <span>Prix des menus ({{ order.people_count }} x {{ menu.basePrice }} €)</span>
                            <span class="font-semibold text-text-main-light">{{ subtotal|number_format(2, ',', ' ') }} €</span>
                        </div>
                        
                        {% if discountAmount > 0 %}
                        <div class="flex justify-between items-center text-primary font-semibold text-sm">
                            <span>Remise quantité (-10%)</span>
                            <span>- {{ discountAmount|number_format(2, ',', ' ') }} €</span>
                        </div>
                        {% endif %}

                        <div class="flex justify-between items-center text-sm">
                            <span>Frais de livraison</span>
                            <span class="font-semibold text-text-main-light">{{ deliveryFee|number_format(2, ',', ' ') }} €</span>
                        </div>
                        <div class="flex justify-between items-center text-xs text-gray-400">
                            <span>Dont TVA (20%)</span>
                            <span>{{ tva|number_format(2, ',', ' ') }} €</span>
                        </div>
                        <div class="pt-4 mt-4 border-t border-gray-200 flex justify-between items-center">
                            <span class="font-display font-bold text-2xl text-primary uppercase tracking-tight">Total à régler</span>
                            <span class="font-display font-bold text-3xl text-primary">{{ total|number_format(2, ',', ' ') }} €</span>
                        </div>
                    </div>
                </div>

                <div class="flex flex-col-reverse sm:flex-row items-center justify-center gap-4">
                    <a href="{{ path('app_order') }}" class="btn-outline w-full sm:w-auto">
                        Modifier la commande
                    </a>
                    
                    <form action="{{ path('app_order_create') }}" method="POST" class="w-full sm:w-auto">
                        <button type="submit" class="btn-primary w-full">
                            Procéder au paiement
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</main>
{% endblock %}