{% extends 'base.html.twig' %}

{% block title %}Inscription - Vite & Gourmand{% endblock %}

{% block header %}
<nav class="absolute top-0 w-full z-50 py-4 px-6 md:px-12">
    <div class="max-w-7xl mx-auto flex items-center justify-between">
        <a class="flex items-center gap-3 group" href="{{ path('app_home') }}">
            <div class="w-10 h-10 bg-primary flex items-center justify-center rounded-sm text-white font-display font-bold text-xl group-hover:scale-105 transition-transform">VG</div>
            <span class="font-display font-bold text-xl tracking-wide text-text-main-light uppercase">Vite & Gourmand</span>
        </a>
        <div class="hidden md:flex items-center gap-8">
            <a class="text-sm font-semibold hover:text-primary transition-colors" href="{{ path('app_home') }}">Retour à l'accueil</a>
        </div>
    </div>
</nav>
{% endblock %}

{% block footer %}
<footer class="py-6 text-center text-xs text-gray-400 mt-auto">
    <p>© {{ "now"|date("Y") }} Vite & Gourmand. Tous droits réservés.</p>
</footer>
{% endblock %}

{% block body %}
<main class="flex-grow flex items-center justify-center p-6 relative pt-24 pb-12">

    
    <div class="bg-white rounded-2xl shadow-soft w-full max-w-lg p-8 md:p-12 relative z-10">
        <div class="text-center mb-8">
            <div class="w-12 h-12 bg-primary flex items-center justify-center rounded-sm text-white font-display font-bold text-2xl mx-auto mb-6">VG</div>
            <h1 class="font-display font-bold text-3xl text-text-main-light mb-2">Créer votre compte</h1>
            <p class="text-gray-500 text-sm">Rejoignez-nous pour savourer le meilleur de Bordeaux</p>
        </div>

        {{ form_start(registrationForm, {'attr': {'class': 'space-y-5'}}) }}
            
            {% for flash_error in app.flashes('verify_email_error') %}
                <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative mb-4" role="alert">
                    <span class="block sm:inline">{{ flash_error }}</span>
                </div>
            {% endfor %}

            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                <div>
                    {{ form_label(registrationForm.firstName, null, {'label_attr': {'class': 'block text-sm font-semibold text-gray-700 mb-2'}}) }}
                    {{ form_widget(registrationForm.firstName, {'attr': {'class': 'w-full px-4 py-3 rounded-lg border-gray-300 focus:border-primary focus:ring-primary text-sm placeholder-gray-400'}}) }}
                    {{ form_errors(registrationForm.firstName) }}
                </div>
                <div>
                    {{ form_label(registrationForm.lastName, null, {'label_attr': {'class': 'block text-sm font-semibold text-gray-700 mb-2'}}) }}
                    {{ form_widget(registrationForm.lastName, {'attr': {'class': 'w-full px-4 py-3 rounded-lg border-gray-300 focus:border-primary focus:ring-primary text-sm placeholder-gray-400'}}) }}
                    {{ form_errors(registrationForm.lastName) }}
                </div>
            </div>

            <div>
                {{ form_label(registrationForm.email, null, {'label_attr': {'class': 'block text-sm font-semibold text-gray-700 mb-2'}}) }}
                {{ form_widget(registrationForm.email, {'attr': {'class': 'w-full px-4 py-3 rounded-lg border-gray-300 focus:border-primary focus:ring-primary text-sm placeholder-gray-400'}}) }}
                {{ form_errors(registrationForm.email) }}
            </div>

            <div>
                {{ form_label(registrationForm.phone, null, {'label_attr': {'class': 'block text-sm font-semibold text-gray-700 mb-2'}}) }}
                {{ form_widget(registrationForm.phone, {'attr': {'class': 'w-full px-4 py-3 rounded-lg border-gray-300 focus:border-primary focus:ring-primary text-sm placeholder-gray-400'}}) }}
                {{ form_errors(registrationForm.phone) }}
            </div>

            <div>
                {{ form_label(registrationForm.adresse, null, {'label_attr': {'class': 'block text-sm font-semibold text-gray-700 mb-2'}}) }}
                {{ form_widget(registrationForm.adresse, {'attr': {'class': 'w-full px-4 py-3 rounded-lg border-gray-300 focus:border-primary focus:ring-primary text-sm placeholder-gray-400'}}) }}
                {{ form_errors(registrationForm.adresse) }}
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                <div>
                    {{ form_label(registrationForm.codePostal, null, {'label_attr': {'class': 'block text-sm font-semibold text-gray-700 mb-2'}}) }}
                    {{ form_widget(registrationForm.codePostal, {'attr': {'class': 'w-full px-4 py-3 rounded-lg border-gray-300 focus:border-primary focus:ring-primary text-sm placeholder-gray-400'}}) }}
                    {{ form_errors(registrationForm.codePostal) }}
                </div>
                <div>
                    {{ form_label(registrationForm.ville, null, {'label_attr': {'class': 'block text-sm font-semibold text-gray-700 mb-2'}}) }}
                    {{ form_widget(registrationForm.ville, {'attr': {'class': 'w-full px-4 py-3 rounded-lg border-gray-300 focus:border-primary focus:ring-primary text-sm placeholder-gray-400'}}) }}
                    {{ form_errors(registrationForm.ville) }}
                </div>
            </div>

            <div>
                {{ form_label(registrationForm.plainPassword, 'Mot de passe', {'label_attr': {'class': 'block text-sm font-semibold text-gray-700 mb-2'}}) }}
                {{ form_widget(registrationForm.plainPassword, {'attr': {'class': 'w-full px-4 py-3 rounded-lg border-gray-300 focus:border-primary focus:ring-primary text-sm placeholder-gray-400'}}) }}
                {{ form_errors(registrationForm.plainPassword) }}
                <div class="mt-3">
                    <div class="flex gap-1 h-1.5 w-full mb-2">
                        <div class="flex-1 rounded-full bg-gray-200"></div>
                        <div class="flex-1 rounded-full bg-gray-200"></div>
                        <div class="flex-1 rounded-full bg-gray-200"></div>
                        <div class="flex-1 rounded-full bg-gray-200"></div>
                    </div>
                    <p class="text-[11px] text-gray-500 leading-relaxed">
                        <span class="font-semibold">Exigence :</span> Minimum 10 caractères, 1 majuscule, 1 minuscule, 1 chiffre et 1 caractère spécial.
                    </p>
                </div>
            </div>

            <div class="flex items-start pt-2">
                <div class="flex items-center h-5">
                    {{ form_widget(registrationForm.agreeTerms, {'attr': {'class': 'w-4 h-4 border border-gray-300 rounded bg-gray-50 focus:ring-3 focus:ring-primary text-primary'}}) }}
                </div>
                <label class="ml-2 text-sm text-gray-500" for="{{ registrationForm.agreeTerms.vars.id }}">
                    J'accepte les <a class="text-primary hover:underline" href="#">conditions générales</a> et la <a class="text-primary hover:underline" href="#">politique de confidentialité</a>
                </label>
            </div>
            {{ form_errors(registrationForm.agreeTerms) }}

            <button class="btn-primary w-full mt-4" type="submit">
                S'inscrire
            </button>
        {{ form_end(registrationForm) }}

        <div class="mt-10 text-center text-sm border-t border-gray-100 pt-8">
            <span class="text-gray-500">Déjà un compte ?</span>
            <a class="font-semibold text-primary hover:text-red-900 ml-1 transition-colors" href="{{ path('app_login') }}">Se connecter</a>
        </div>
    </div>
</main>
{% endblock %}
