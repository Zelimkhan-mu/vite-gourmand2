{% extends 'dashboard_admin/base.html.twig' %}

{% block title %}Statistiques des ventes - Vite & Gourmand{% endblock %}

{% block admin_content %}

<div class="flex flex-col gap-4 mb-6">

    <form method="get" action="{{ path('admin_stats') }}" class="flex flex-wrap items-center gap-4">
        <select name="menu" class="pl-4 pr-10 py-2 border border-gray-200 rounded-lg text-sm focus:ring-primary focus:border-primary bg-white text-gray-600">
            <option value="">Tous les menus</option>
            {% for menu in menus %}
                <option value="{{ menu.id }}" {{ currentMenu == menu.id ? 'selected' : '' }}>
                    {{ menu.titre }}
                </option>
            {% endfor %}
        </select>

        <div class="flex items-center gap-2 bg-white border border-gray-200 rounded-lg p-1">
            <input type="date" name="date_from" value="{{ dateFrom }}"
                   class="border-0 bg-transparent text-sm text-gray-600 focus:ring-0 p-1">
            <span class="text-gray-400 text-xs">–</span>
            <input type="date" name="date_to" value="{{ dateTo }}"
                   class="border-0 bg-transparent text-sm text-gray-600 focus:ring-0 p-1">
        </div>

        <button type="submit" class="px-4 py-2 bg-primary text-white text-sm font-semibold rounded-lg hover:bg-red-900 transition-colors">
            Filtrer
        </button>
    </form>

    <div class="bg-white rounded-xl shadow-soft px-6 py-4 flex items-center justify-between border-l-4 border-primary">
        <h2 class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Chiffre d'Affaires Total</h2>
        <span class="font-display font-bold text-2xl text-primary">{{ totalCA|number_format(2, ',', ' ') }} €</span>
    </div>

</div>

<div class="bg-white rounded-2xl shadow-soft overflow-hidden border border-gray-50">
    <div class="px-6 py-4 border-b border-gray-100">
        <h3 class="font-display font-bold text-lg text-text-main">Détail par Menu</h3>
    </div>

    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="bg-gray-50/50 border-b border-gray-100 text-xs uppercase tracking-wider text-gray-500 font-semibold">
                    <th class="px-6 py-4">Menu</th>
                    <th class="px-6 py-4 text-center">Commandes</th>
                    <th class="px-6 py-4 text-right">Chiffre d'Affaires</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
                {% for row in stats %}
                <tr class="hover:bg-gray-50/50 transition-colors">
                    <td class="px-6 py-4 font-bold text-text-main">{{ row.menuTitre }}</td>
                    <td class="px-6 py-4 text-center">
                        <span class="font-semibold text-gray-700 bg-gray-100 px-3 py-1 rounded-full">{{ row.count }}</span>
                    </td>
                    <td class="px-6 py-4 text-right">
                        <span class="font-display font-bold text-primary text-lg">{{ row.totalCA|number_format(2, ',', ' ') }} €</span>
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="3" class="px-6 py-12 text-center text-gray-400">
                        <span class="material-icons-outlined text-4xl block mb-2">bar_chart</span>
                        Aucune donnée disponible pour ces critères.
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

{% endblock %}