{% extends 'base.html.twig' %}

{% block title %}Administration - Vite &amp; Gourmand{% endblock %}

{% block body_class %}bg-[#F9F9F9] font-body text-text-main-light h-screen flex overflow-hidden antialiased{% endblock %}

{% block body_attributes %}x-data="{ sidebarOpen: false }"{% endblock %}

{% block header %}{% endblock %}
{% block footer %}{% endblock %}

{% block body %}
    <div x-show="sidebarOpen" @click="sidebarOpen = false" x-transition:enter="transition-opacity ease-linear duration-300" x-transition:enter-start="opacity-0" x-transition:enter-end="opacity-100" x-transition:leave="transition-opacity ease-linear duration-300" x-transition:leave-start="opacity-100" x-transition:leave-end="opacity-0" class="fixed inset-0 bg-gray-900/80 z-40 lg:hidden" style="display: none;"></div>

    <aside :class="sidebarOpen ? 'translate-x-0' : '-translate-x-full'" class="fixed inset-y-0 left-0 z-50 w-64 bg-white border-r border-gray-100 flex flex-col h-full transition-transform duration-300 transform lg:translate-x-0 lg:static lg:inset-0 shadow-xl lg:shadow-none">
        <div class="p-8 flex items-center justify-center relative">
            <button @click="sidebarOpen = false" class="absolute top-4 right-4 text-gray-400 hover:text-gray-500 lg:hidden">
                <span class="material-icons-outlined">close</span>
            </button>
            <a href="{{ path('app_home') }}" class="flex flex-col items-center gap-3 hover:opacity-80 transition-opacity">
                <img src="{{ asset('images/logo.svg') }}" alt="Vite & Gourmand" class="h-12 w-auto">
                <span class="hidden lg:block font-display font-bold text-lg tracking-wide text-primary uppercase">Administration</span>
            </a>
        </div>

        <nav class="flex-1 px-4 py-6 space-y-2 overflow-y-auto">
            <a class="flex items-center gap-4 px-4 py-3 {{ app.request.attributes.get('_route') == 'admin_orders_list' ? 'bg-primary/5 text-primary font-semibold' : 'text-gray-500 hover:bg-gray-50 hover:text-primary font-medium' }} rounded-lg transition-colors" href="{{ path('admin_orders_list') }}">
                <span class="material-icons-outlined text-[22px]">shopping_cart</span>
                Commandes
            </a>

            <a class="flex items-center gap-4 px-4 py-3 {{ app.request.attributes.get('_route') starts with 'admin_menus' ? 'bg-primary/5 text-primary font-semibold' : 'text-gray-500 hover:bg-gray-50 hover:text-primary font-medium' }} rounded-lg transition-colors" href="{{ path('admin_menus_list') }}">
                <span class="material-icons-outlined text-[22px]">restaurant_menu</span>
                Menus
            </a>

            <a class="flex items-center gap-4 px-4 py-3 {{ app.request.attributes.get('_route') starts with 'admin_plat' ? 'bg-primary/5 text-primary font-semibold' : 'text-gray-500 hover:bg-gray-50 hover:text-primary font-medium' }} rounded-lg transition-colors" href="{{ path('admin_plats_list') }}">
                <span class="material-icons-outlined text-[22px]">dinner_dining</span>
                Plats
            </a>

            <a class="flex items-center gap-4 px-4 py-3 {{ app.request.attributes.get('_route') starts with 'admin_reviews' ? 'bg-primary/5 text-primary font-semibold' : 'text-gray-500 hover:bg-gray-50 hover:text-primary font-medium' }} rounded-lg transition-colors" href="{{ path('admin_reviews_list') }}">
                <span class="material-icons-outlined text-[22px]">reviews</span>
                Avis
            </a>

            <a class="flex items-center gap-4 px-4 py-3 {{ app.request.attributes.get('_route') starts with 'admin_horaires' ? 'bg-primary/5 text-primary font-semibold' : 'text-gray-500 hover:bg-gray-50 hover:text-primary font-medium' }} rounded-lg transition-colors" href="{{ path('admin_horaires') }}">
                <span class="material-icons-outlined text-[22px]">schedule</span>
                Horaires
            </a>

            {% if is_granted('ROLE_ADMIN') %}
                <div class="pt-4 mt-4 border-t border-gray-100">
                    <p class="px-4 text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">Administration</p>
                    <a class="flex items-center gap-4 px-4 py-3 {{ app.request.attributes.get('_route') == 'admin_users_list' ? 'bg-primary/5 text-primary font-semibold' : 'text-gray-500 hover:bg-gray-50 hover:text-primary font-medium' }} rounded-lg transition-colors" href="{{ path('admin_users_list') }}">
                        <span class="material-icons-outlined text-[22px]">group</span>
                        Employés
                    </a>
                    <a class="flex items-center gap-4 px-4 py-3 text-gray-500 hover:bg-gray-50 hover:text-primary rounded-lg font-medium transition-colors" href="{{ path('admin_stats') }}">
                        <span class="material-icons-outlined text-[22px]">bar_chart</span>
                        Statistiques
                    </a>
                </div>
            {% endif %}
        </nav>

        <div class="p-4 border-t border-gray-100">
            <a class="flex items-center gap-4 px-4 py-3 text-gray-500 hover:text-red-600 font-medium transition-colors" href="{{ path('app_logout') }}">
                <span class="material-icons-outlined">logout</span>
                Déconnexion
            </a>
        </div>
    </aside>

    <main class="flex-1 flex flex-col h-full overflow-hidden relative w-full">
        <header class="h-16 bg-white border-b border-gray-100 flex items-center justify-between px-4 lg:hidden flex-shrink-0 relative">
            <button @click="sidebarOpen = true" class="text-gray-500 hover:text-primary p-2 -ml-2">
                <span class="material-icons-outlined text-2xl">menu</span>
            </button>
            <div class="absolute left-1/2 top-1/2 transform -translate-x-1/2 -translate-y-1/2">
                <img src="{{ asset('images/logo.svg') }}" alt="Vite & Gourmand" class="h-8 w-auto">
            </div>
            <div class="w-8"></div>
        </header>

        <header class="hidden lg:flex h-20 bg-white border-b border-gray-100 items-center justify-between px-8 flex-shrink-0">
            <h1 class="font-display font-bold text-2xl text-text-main-light">
                {% block page_title %}Administration{% endblock %}
            </h1>
            <div class="flex items-center gap-4">
                {% block header_actions %}{% endblock %}
                <div class="text-right hidden md:block">
                    <p class="text-sm font-semibold text-text-main-light">{{ app.user.firstname }} {{ app.user.lastname }}</p>
                    <p class="text-xs text-gray-500">
                        {{ is_granted('ROLE_ADMIN') ? 'Administrateur' : 'Employé' }}
                    </p>
                </div>
            </div>
        </header>

        <div class="flex-1 overflow-y-auto p-8 lg:p-12">
            <div>
                {% for message in app.flashes('success') %}
                    <div class="mb-4 px-4 py-3 bg-green-50 border border-green-200 text-green-700 rounded-xl text-sm font-medium">
                        {{ message }}
                    </div>
                {% endfor %}
                {% for message in app.flashes('error') %}
                    <div class="mb-4 px-4 py-3 bg-red-50 border border-red-200 text-red-700 rounded-xl text-sm font-medium">
                        {{ message }}
                    </div>
                {% endfor %}
                {% block admin_content %}{% endblock %}
            </div>
        </div>
    </main>
    <script src="//unpkg.com/alpinejs" defer></script>
{% endblock %}