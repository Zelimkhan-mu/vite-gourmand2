{% extends 'base.html.twig' %}

{% block title %}Email envoyé - Vite & Gourmand{% endblock %}

{% block header %}
<nav class="sticky top-0 z-50 bg-white shadow-sm py-4 px-6 md:px-12 transition-colors duration-300">
    <div class="max-w-7xl mx-auto flex items-center justify-between">
        <a class="flex items-center gap-3 group" href="{{ path('app_home') }}">
             <img src="{{ asset('images/logo.svg') }}" alt="Vite & Gourmand" class="h-10 w-auto group-hover:scale-105 transition-transform">
            <span class="font-display font-bold text-xl tracking-wide text-text-main-light uppercase">Vite &amp; Gourmand</span>
        </a>
        <div class="flex items-center gap-8">
            <a class="text-sm font-semibold hover:text-primary transition-colors" href="{{ path('app_home') }}">Retour à l'accueil</a>
        </div>
    </div>
</nav>
{% endblock %}

{% block body %}
<main class="flex-grow flex items-center justify-center p-6 relative min-h-screen">


    <div class="bg-white rounded-2xl shadow-soft w-full max-w-lg p-8 md:p-12 relative z-10 text-center">
        <div class="mb-8">
            <span class="material-icons-outlined text-gold text-6xl mb-6">mail</span>
            <h1 class="font-display font-bold text-3xl text-text-main-light mb-4">Vérifiez votre boîte mail</h1>
            <p class="text-gray-600 leading-relaxed max-w-sm mx-auto">
                Si un compte existe pour cette adresse, un lien de réinitialisation a été envoyé.
                Veuillez cliquer sur ce lien pour choisir un nouveau mot de passe.
            </p>
            <p class="text-xs text-gray-400 mt-2">
                Le lien expirera dans {{ resetToken.expirationMessageKey|trans(resetToken.expirationMessageData, 'ResetPasswordBundle') }}.
            </p>
        </div>

        <div class="pt-4">
            <p class="text-sm text-gray-500">
                Vous n'avez rien reçu ?
                <a class="font-semibold text-primary hover:text-red-900 transition-colors underline-offset-4 hover:underline ml-1" href="{{ path('app_forgot_password_request') }}">
                    Renvoyer le lien
                </a>
            </p>
        </div>

        <div class="mt-10 pt-8 border-t border-gray-100">
            <a class="text-sm font-semibold text-gray-400 hover:text-primary transition-colors flex items-center justify-center gap-2" href="{{ path('app_login') }}">
                <span class="material-icons-outlined text-base">arrow_back</span>
                Retour à la connexion
            </a>
        </div>
    </div>
</main>
{% endblock %}

{% block footer %}
<footer class="py-6 text-center text-xs text-gray-400">
    <p>© {{ 'now'|date('Y') }} Vite &amp; Gourmand. Tous droits réservés.</p>
</footer>
{% endblock %}