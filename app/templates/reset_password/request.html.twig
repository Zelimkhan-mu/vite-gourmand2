{% extends 'base.html.twig' %}

{% block title %}Mot de passe oublié - Vite & Gourmand{% endblock %}

{% block header %}
<nav class="sticky top-0 z-50 bg-white shadow-sm py-4 px-6 md:px-12 transition-colors duration-300">
    <div class="max-w-7xl mx-auto flex items-center justify-between">
        <a class="flex items-center gap-3 group" href="{{ path('app_home') }}">
             <img src="{{ asset('images/logo.svg') }}" alt="Vite & Gourmand" class="h-10 w-auto group-hover:scale-105 transition-transform">
            <span class="font-display font-bold text-xl tracking-wide text-text-main-light uppercase">Vite &amp; Gourmand</span>
        </a>
        <div class="hidden md:flex items-center gap-8">
            <a class="text-sm font-semibold hover:text-primary transition-colors" href="{{ path('app_home') }}">Retour à l'accueil</a>
        </div>
    </div>
</nav>
{% endblock %}

{% block body %}
<main class="flex-grow flex items-center justify-center p-6 relative min-h-screen">


    <div class="bg-white rounded-2xl shadow-soft w-full max-w-md p-8 md:p-12 relative z-10">
        <div class="text-center mb-8">
            <div class="w-12 h-12 bg-primary flex items-center justify-center rounded-sm text-white font-display font-bold text-2xl mx-auto mb-6">VG</div>
            <h1 class="font-display font-bold text-3xl text-text-main-light mb-2">Mot de passe oublié ?</h1>
            <p class="text-gray-500 text-sm">Saisissez votre adresse email pour recevoir un lien de réinitialisation.</p>
        </div>

        {% for flash_error in app.flashes('reset_password_error') %}
            <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative mb-4" role="alert">
                <span class="block sm:inline">{{ flash_error }}</span>
            </div>
        {% endfor %}

        {{ form_start(requestForm, {'attr': {'class': 'space-y-6'}}) }}
            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-2" for="{{ requestForm.email.vars.id }}">Adresse email</label>
                {{ form_widget(requestForm.email, {'attr': {'class': 'w-full px-4 py-3 rounded-lg border-gray-300 focus:border-primary focus:ring-primary text-sm placeholder-gray-400', 'placeholder': 'exemple@email.com'}}) }}
                {{ form_errors(requestForm.email, {'attr': {'class': 'text-red-500 text-xs mt-1'}}) }}
            </div>

            <button class="w-full bg-primary hover:bg-red-900 text-white font-bold py-3.5 px-6 rounded-pill shadow-md hover:shadow-lg transition-all transform hover:-translate-y-0.5 text-center" type="submit">
                Envoyer le lien
            </button>
        {{ form_end(requestForm) }}

        <div class="mt-8 text-center text-sm">
            <a class="font-semibold text-primary hover:text-red-900 transition-colors flex items-center justify-center gap-2" href="{{ path('app_login') }}">
                <span class="material-icons-outlined text-sm">arrow_back</span>
                Retour à la connexion
            </a>
        </div>
    </div>
</main>
{% endblock %}

{% block footer %}
<footer class="py-6 text-center text-xs text-gray-400">
    <p>© {{ 'now'|date('Y') }} Vite &amp; Gourmand. Tous droits réservés.</p>
</footer>
{% endblock %}