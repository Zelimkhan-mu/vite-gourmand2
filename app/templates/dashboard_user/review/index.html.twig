{% extends 'dashboard_user/base.html.twig' %}

{% block title %}Mes Avis - Vite & Gourmand{% endblock %}

{% block dashboard_content %}
    <h2 class="font-display font-bold text-3xl text-text-main-light mb-8">Mes Avis</h2>

    <div class="space-y-6">
        {% import 'partials/_macros.html.twig' as macros %}
        {% for review in reviews %}
            <div class="hidden md:grid bg-white rounded-2xl shadow-soft p-6 border border-gray-100 grid-cols-12 gap-6 items-start {{ review.statut == 'refusé' ? 'opacity-75' : '' }}">
                <div class="col-span-3 space-y-2">
                    <h3 class="font-bold text-lg text-primary">Commande #VG-{{ review.commande.id }}</h3>
                    <p class="text-text-main-light font-semibold">{{ review.commande.menu ? review.commande.menu.titre : 'Menu supprimé' }}</p>
                    <p class="text-sm text-gray-500">Date de commande : {{ review.commande.createdAt|date('d M Y') }}</p>
                </div>
                <div class="col-span-6 space-y-3">
                    <div class="flex items-center gap-1">
                        {% for i in 1..5 %}
                            {% if i <= review.rating %}
                                <span class="material-icons-outlined text-[#D4AF37] text-xl">star</span>
                            {% else %}
                                <span class="material-icons-outlined text-gray-300 text-xl">star</span>
                            {% endif %}
                        {% endfor %}
                    </div>
                    <p class="text-text-main-light italic">"{{ review.commentaire }}"</p>
                </div>
                <div class="col-span-3 flex flex-col items-end gap-2">
                    {{ macros.badge_statut_commande(review.statut) }}
                    <p class="text-xs text-gray-400">Date de l'avis : {{ review.createdAt|date('d M Y') }}</p>
                </div>
            </div>

            <div class="md:hidden bg-white rounded-2xl shadow-soft p-5 border border-gray-50 flex flex-col gap-4">
                <div class="flex justify-between items-center">
                    <span class="font-bold text-primary text-sm tracking-wide">#VG-{{ review.commande.id }}</span>
                    {{ macros.badge_statut_commande(review.statut) }}
                </div>
                <div class="flex flex-col gap-1">
                    <h3 class="font-display font-bold text-xl text-text-main-light leading-tight">{{ review.commande.menu ? review.commande.menu.titre : 'Menu supprimé' }}</h3>
                    <div class="flex items-center gap-0.5">
                         {% for i in 1..5 %}
                            {% if i <= review.rating %}
                                <span class="material-icons-outlined text-[#D4AF37] text-lg">star</span>
                            {% else %}
                                <span class="material-icons-outlined text-gray-300 text-lg">star</span>
                            {% endif %}
                        {% endfor %}
                    </div>
                </div>
                <div class="flex flex-col gap-0.5 border-t border-gray-50 pt-3">
                    <p class="text-[11px] text-gray-500 uppercase tracking-wider">Commande : {{ review.commande.createdAt|date('d M Y') }}</p>
                    <p class="text-[11px] text-gray-400 uppercase tracking-wider">Avis : {{ review.createdAt|date('d M Y') }}</p>
                </div>
                <div class="bg-gray-50/50 rounded-xl p-3">
                    <p class="text-sm text-text-main-light italic leading-relaxed">
                        "{{ review.commentaire }}"
                    </p>
                </div>
            </div>
        {% else %}
            <div class="text-center py-12 text-gray-500">
                <span class="material-icons-outlined text-4xl mb-2 block">rate_review</span>
                <p>Vous n'avez pas encore laissé d'avis.</p>
            </div>
        {% endfor %}
    </div>
{% endblock %}
